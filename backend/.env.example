# Production Environment Variables for Backend
# Copy this to .env and fill in your values

# Supabase PostgreSQL Database URL (REQUIRED)
# Get this from Supabase Dashboard → Settings → Database → Connection String (URI)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Google Gemini API Keys (REQUIRED) - comma separated for rotation
# Get from https://aistudio.google.com/apikey
GEMINI_KEYS=your_key_1,your_key_2,your_key_3

# Serper API Key (OPTIONAL) - for live web grounding
# Get from https://serper.dev
SERPER_API_KEY=your_serper_key

# CORS Origins (REQUIRED for production)
# Your Vercel frontend URL
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173